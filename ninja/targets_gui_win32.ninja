# 需先有：builddir、exe_ext

situation_view_bin = $builddir/cmd/situation_view/situation_view$exe_ext

build $situation_view_bin: link_gui cmd/situation_view/situation_view.cpp $builddir/lib/core/log.o $builddir/lib/core/error.o $builddir/lib/math/vec3.o $builddir/lib/math/linalg.o $builddir/lib/ecs/entity_coordinate_system.o $builddir/lib/motion/motion_model_3dof.o $builddir/lib/engine/types.o $builddir/lib/engine/engine.o $builddir/lib/engine/engine_mount.o $builddir/lib/engine/engine_mover.o $builddir/lib/engine/engine_sensor.o $builddir/lib/scenario/parse.o $builddir/lib/render/gl_window.o $builddir/lib/render/gl_window_factory.o $builddir/lib/render/gl_window_win32.o $builddir/lib/render/texture_bmp.o $builddir/lib/render/svg_line_texture.o $builddir/lib/render/world_vector_merc.o $builddir/lib/render/world_vector_lines.o $builddir/lib/render/globe_program.o $builddir/lib/render/tactical_map_2d.o $builddir/lib/render/lonlat_grid.o $builddir/lib/render/globe_view_3d.o $builddir/lib/situation_view/situation_view_shell.o $builddir/lib/situation_view/situation_view_chrome.o $builddir/lib/situation_view/situation_view_chrome_win32.o $builddir/lib/situation_view/asset_paths.o $builddir/lib/situation_view/icon_texture_cache.o $builddir/lib/situation_view/situation_map_globe_render.o
